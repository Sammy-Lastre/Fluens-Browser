<FluentCard>
    <FluentStack Orientation="Orientation.Vertical">
        <FluentLabel>Settings</FluentLabel>

        @foreach (SettingsSectionItem sectionItem in PrimarySections)
        {
            <FluentButton Appearance="@GetAppearance(sectionItem.Id)"
                          Disabled="@(sectionItem.Id == SelectedSection)"
                          @onclick="() => SelectSection(sectionItem.Id)">
                @sectionItem.Label
            </FluentButton>
        }

        <FluentDivider />

        @foreach (SettingsSectionItem sectionItem in SecondarySections)
        {
            <FluentButton Appearance="@GetAppearance(sectionItem.Id)"
                          Disabled="@(sectionItem.Id == SelectedSection)"
                          @onclick="() => SelectSection(sectionItem.Id)">
                @sectionItem.Label
            </FluentButton>
        }
    </FluentStack>
</FluentCard>

@code {
    [Parameter]
    public SettingsSection SelectedSection { get; set; }

    [Parameter]
    public EventCallback<SettingsSection> SelectedSectionChanged { get; set; }

    private static IReadOnlyList<SettingsSectionItem> PrimarySections { get; } =
    [
        new(SettingsSection.Profiles, "Profiles"),
        new(SettingsSection.AppearanceAndBehavior, "Appearance and behavior"),
        new(SettingsSection.PrivacyAndSecurity, "Privacy and security"),
        new(SettingsSection.Performance, "Performance"),
        new(SettingsSection.SearchEngine, "Search engine"),
        new(SettingsSection.DefaultBrowser, "Default browser"),
        new(SettingsSection.OnStartup, "On startup")
    ];

    private static IReadOnlyList<SettingsSectionItem> SecondarySections { get; } =
    [
        new(SettingsSection.Languages, "Languages"),
        new(SettingsSection.Downloads, "Downloads"),
        new(SettingsSection.Accessibility, "Accessibility"),
        new(SettingsSection.System, "System"),
        new(SettingsSection.ResetSettings, "Reset settings"),
        new(SettingsSection.Extensions, "Extensions"),
        new(SettingsSection.About, "About Fluens")
    ];

    private Appearance GetAppearance(SettingsSection section)
    {
        return section == SelectedSection ? Appearance.Accent : Appearance.Stealth;
    }

    private Task SelectSection(SettingsSection section)
    {
        if (section == SelectedSection)
        {
            return Task.CompletedTask;
        }

        return SelectedSectionChanged.InvokeAsync(section);
    }

    private sealed record SettingsSectionItem(SettingsSection Id, string Label);
}
