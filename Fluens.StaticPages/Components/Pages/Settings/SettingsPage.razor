<FluentGrid Justify="JustifyContent.Center" Style="width: 100%">
    <FluentGridItem>
        <FluentStack VerticalGap="8" Orientation="Orientation.Vertical">
            <FluentLabel>@GetSectionTitle(SelectedSection)</FluentLabel>

            @if (IsSearchMismatch)
            {
                <SettingsPlaceholderSection Title="No matching setting"
                                            Description="Try a different search term or select a section from the sidebar." />
            }
            else if (SelectedSection == SettingsSection.OnStartup)
            {
                <OnStartupSettingsSection />
            }
            else if (SelectedSection == SettingsSection.PrivacyAndSecurity)
            {
                <PrivacyAndSecuritySettingsSection />
            }
            else
            {
                <SettingsPlaceholderSection Title="@GetSectionTitle(SelectedSection)"
                                            Description="@GetSectionDescription(SelectedSection)" />
            }
        </FluentStack>
    </FluentGridItem>
</FluentGrid>

@code {
    [Parameter]
    public string? SectionSlug { get; set; }

    private SettingsSection SelectedSection { get; set; } = SettingsSection.OnStartup;
    private string SearchText { get; set; } = string.Empty;
    private string? LastAppliedSectionSlug { get; set; }

    protected override void OnParametersSet()
    {
        if (string.Equals(LastAppliedSectionSlug, SectionSlug, StringComparison.Ordinal))
        {
            return;
        }

        SelectedSection = ParseSection(SectionSlug);
        LastAppliedSectionSlug = SectionSlug;
    }

    private bool IsSearchMismatch
        => !string.IsNullOrWhiteSpace(SearchText)
           && !GetSectionTitle(SelectedSection).Contains(SearchText, StringComparison.OrdinalIgnoreCase);

    private Task OnSelectedSectionChangedAsync(SettingsSection section)
    {
        SelectedSection = section;
        return Task.CompletedTask;
    }

    private Task OnSearchChangedAsync(string searchText)
    {
        SearchText = searchText;

        if (string.IsNullOrWhiteSpace(searchText))
        {
            return Task.CompletedTask;
        }

        SettingsSection? matchedSection = GetSections()
            .FirstOrDefault(section => GetSectionTitle(section).Contains(searchText, StringComparison.OrdinalIgnoreCase));

        if (matchedSection is not null)
        {
            SelectedSection = matchedSection.Value;
        }

        return Task.CompletedTask;
    }

    private static IEnumerable<SettingsSection> GetSections()
    {
        return Enum.GetValues<SettingsSection>();
    }

    private static SettingsSection ParseSection(string? sectionSlug)
    {
        return sectionSlug?.Trim().ToLowerInvariant() switch
        {
            "profiles" => SettingsSection.Profiles,
            "appearance-and-behavior" => SettingsSection.AppearanceAndBehavior,
            "privacy-and-security" => SettingsSection.PrivacyAndSecurity,
            "performance" => SettingsSection.Performance,
            "search-engine" => SettingsSection.SearchEngine,
            "default-browser" => SettingsSection.DefaultBrowser,
            "on-startup" => SettingsSection.OnStartup,
            "languages" => SettingsSection.Languages,
            "downloads" => SettingsSection.Downloads,
            "accessibility" => SettingsSection.Accessibility,
            "system" => SettingsSection.System,
            "reset-settings" => SettingsSection.ResetSettings,
            "extensions" => SettingsSection.Extensions,
            "about" => SettingsSection.About,
            _ => SettingsSection.OnStartup
        };
    }

    private static string GetSectionTitle(SettingsSection section)
    {
        return section switch
        {
            SettingsSection.Profiles => "Profiles",
            SettingsSection.AppearanceAndBehavior => "Appearance and behavior",
            SettingsSection.PrivacyAndSecurity => "Privacy and security",
            SettingsSection.Performance => "Performance",
            SettingsSection.SearchEngine => "Search engine",
            SettingsSection.DefaultBrowser => "Default browser",
            SettingsSection.OnStartup => "On startup",
            SettingsSection.Languages => "Languages",
            SettingsSection.Downloads => "Downloads",
            SettingsSection.Accessibility => "Accessibility",
            SettingsSection.System => "System",
            SettingsSection.ResetSettings => "Reset settings",
            SettingsSection.Extensions => "Extensions",
            SettingsSection.About => "About Fluens",
            _ => "Settings"
        };
    }

    private static string GetSectionDescription(SettingsSection section)
    {
        return section switch
        {
            SettingsSection.Profiles => "Manage signed-in profiles and profile sync preferences.",
            SettingsSection.AppearanceAndBehavior => "Configure theme, toolbar behavior, and startup surface preferences.",
            SettingsSection.PrivacyAndSecurity => "Control browsing data, permissions, and security-related protections.",
            SettingsSection.Performance => "Tune resource usage, background activity, and speed preferences.",
            SettingsSection.SearchEngine => "Choose the default search engine and manage search shortcuts.",
            SettingsSection.DefaultBrowser => "Review default browser status and file/protocol association settings.",
            SettingsSection.OnStartup => "Choose what Fluens opens when a new browser session starts.",
            SettingsSection.Languages => "Manage display language and translation preferences.",
            SettingsSection.Downloads => "Set download location and ask-where-to-save behavior.",
            SettingsSection.Accessibility => "Enable accessibility options for readability and navigation support.",
            SettingsSection.System => "Manage background mode and system integration options.",
            SettingsSection.ResetSettings => "Restore defaults and reset selected browser preferences.",
            SettingsSection.Extensions => "Review installed extensions and extension permissions.",
            SettingsSection.About => "View current version and update channel information.",
            _ => "Manage browser settings."
        };
    }
}
